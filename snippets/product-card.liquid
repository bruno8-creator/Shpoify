<a class="product-card" href="{{ product.url }}">
  <div class="product-card__media">
    {% if product.featured_image %}
      {% assign card_image_alt = product.featured_image.alt | default: product.title %}
      {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: card_image_alt }}
    {% else %}
      <div class="placeholder-media">{{ 'product-1' | placeholder_svg_tag }}</div>
    {% endif %}
  </div>
  <div class="product-card__content">
    <h3>{{ product.title }}</h3>
    <div class="price">
      {% if product.compare_at_price > product.price %}
        <span>{{ product.price | money }}</span>
        <s>{{ product.compare_at_price | money }}</s>
      {% else %}
        {{ product.price | money }}
      {% endif %}
    </div>
  </div>
</a>
