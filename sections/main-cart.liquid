<section class="page-template">
  <div class="page-width">
    <div class="section-heading">
      <h1>{{ 'cart.title' | t }}</h1>
    </div>

    {% if cart.item_count == 0 %}
      <div class="empty-state">
        <p>{{ 'cart.empty' | t }}</p>
        <a class="button" href="{{ routes.all_products_collection_url }}">Seguir comprando</a>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Producto</th>
              <th>Cantidad</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td>
                  <div class="cart-line">
                    {% if item.image %}
                      {{ item.image | image_url: width: 180 | image_tag: loading: 'lazy', alt: item.product.title }}
                    {% endif %}
                    <div>
                      <strong>{{ item.product.title }}</strong>
                      {% unless item.product.has_only_default_variant %}
                        <div>{{ item.variant.title }}</div>
                      {% endunless %}
                      <a href="{{ item.url_to_remove }}">Eliminar</a>
                    </div>
                  </div>
                </td>
                <td>
                  <input class="input quantity-input" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                </td>
                <td>{{ item.final_line_price | money }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <div class="cart-summary">
          <strong>{{ 'cart.subtotal' | t }}: {{ cart.total_price | money }}</strong>
          <button class="button button--secondary" type="submit" name="update">{{ 'cart.update' | t }}</button>
          <button class="button" type="submit" name="checkout">{{ 'cart.checkout' | t }}</button>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Carrito principal"
}
{% endschema %}
