{% liquid
  assign hero_image = section.settings.image
  if hero_image != blank
    assign hero_background = hero_image | image_url: width: 2400
  else
    assign hero_background = 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=2400&q=80'
  endif
%}

<section class="hero" style="--hero-image: url('{{ hero_background }}');">
  <div class="hero__content">
    {% if section.settings.eyebrow != blank %}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
    <div class="hero__actions">
      {% if section.settings.primary_label != blank %}
        <a class="button" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>
      {% endif %}
      {% if section.settings.secondary_label != blank %}
        <a class="button button--secondary" href="{{ section.settings.secondary_link | default: '/collections' }}">{{ section.settings.secondary_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero principal",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Posavasos de silicona para el día a día"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Protege tu mesa con estilo"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Posavasos antideslizantes, resistentes al calor y fáciles de limpiar para café, té, vasos y termos."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Botón principal",
      "default": "Ver posavasos"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Enlace principal"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Botón secundario",
      "default": "Elegir color"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Enlace secundario"
    }
  ],
  "presets": [
    {
      "name": "Hero principal"
    }
  ]
}
{% endschema %}
