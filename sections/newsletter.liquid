<section class="newsletter section-spacing">
  <div class="page-width newsletter__inner">
    <div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>

    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input class="input" type="email" name="contact[email]" placeholder="tu@email.com" required>
      <button class="button" type="submit">{{ section.settings.button_label }}</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Ofertas y nuevos colores"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Recibe novedades del posavasos, descuentos y próximas combinaciones de color."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Botón",
      "default": "Suscribirme"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
