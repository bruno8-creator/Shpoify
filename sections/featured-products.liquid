{% assign collection = section.settings.collection %}

<section class="section-spacing">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {% if collection != blank %}
        <a class="button button--secondary" href="{{ collection.url }}">Ver todo</a>
      {% endif %}
    </div>

    <div class="product-grid">
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: section.settings.product_limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for product in collections.all.products limit: section.settings.product_limit %}
          {% render 'product-card', product: product %}
        {% else %}
          <div class="empty-state">
            Añade productos en Shopify para que aparezcan aquí.
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Productos destacados",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Favoritos de casa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Productos que simplifican tu día"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Número de productos",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Productos destacados"
    }
  ]
}
{% endschema %}
