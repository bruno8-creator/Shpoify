<section class="trust-row">
  <div class="page-width">
    <div class="trust-row__inner">
      {% for block in section.blocks %}
        <div class="trust-item" {{ block.shopify_attributes }}>
          <strong>{{ block.settings.title }}</strong>
          <span>{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beneficios",
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Resistente al calor"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Pensado para tazas, café, té, termos y recipientes calientes."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "title": "Base antideslizante", "text": "Mejor agarre para proteger superficies y evitar pequeños movimientos." } },
        { "type": "benefit", "settings": { "title": "Fácil de limpiar", "text": "Silicona flexible, reutilizable y lista para volver a usar en segundos." } }
      ]
    }
  ]
}
{% endschema %}
