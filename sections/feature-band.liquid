<section class="feature-band section-spacing">
  <div class="page-width feature-band__grid">
    <div class="feature-band__image">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        <img
          src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?auto=format&fit=crop&w=1200&q=80"
          alt="Salón ordenado con decoración natural"
          loading="lazy"
          width="1200"
          height="1500"
        >
      {% endif %}
    </div>

    <div>
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>

      <div class="feature-list">
        {% for block in section.blocks %}
          <div class="feature-list__item" {{ block.shopify_attributes }}>
            <span class="feature-list__number">{{ forloop.index }}</span>
            <div>
              <strong>{{ block.settings.title }}</strong>
              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloque editorial",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Compra con intención"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Menos ruido, más hogar"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Elegimos productos útiles, resistentes y fáciles de integrar en espacios reales."
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Punto",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Funcionalidad primero"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Cada producto debe resolver algo concreto en tu día a día."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloque editorial",
      "blocks": [
        { "type": "point" },
        { "type": "point", "settings": { "title": "Materiales duraderos", "text": "Buscamos piezas pensadas para acompañarte más tiempo." } },
        { "type": "point", "settings": { "title": "Estética tranquila", "text": "Colores y formas fáciles de combinar con cualquier hogar." } }
      ]
    }
  ]
}
{% endschema %}
