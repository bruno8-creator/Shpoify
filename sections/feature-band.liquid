<section class="feature-band section-spacing">
  <div class="page-width feature-band__grid">
    <div class="feature-band__image">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        <img
          src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=1200&q=80"
          alt="Taza de café sobre una mesa"
          loading="lazy"
          width="1200"
          height="1500"
        >
      {% endif %}
    </div>

    <div>
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>

      <div class="feature-list">
        {% for block in section.blocks %}
          <div class="feature-list__item" {{ block.shopify_attributes }}>
            <span class="feature-list__number">{{ forloop.index }}</span>
            <div>
              <strong>{{ block.settings.title }}</strong>
              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bloque editorial",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Pequeño detalle, gran diferencia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Tu mesa protegida cada día"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Un buen posavasos evita marcas, absorbe mejor el uso diario y hace que cualquier café se sienta más cuidado."
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Punto",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Ranuras que drenan"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "El diseño estriado ayuda a separar pequeñas gotas de la base del vaso."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bloque editorial",
      "blocks": [
        { "type": "point" },
        { "type": "point", "settings": { "title": "Silicona flexible", "text": "No raya la mesa, se guarda fácil y se limpia con agua y jabón." } },
        { "type": "point", "settings": { "title": "Varios colores", "text": "Elige el tono que mejor combine con tu cocina, escritorio o comedor." } }
      ]
    }
  ]
}
{% endschema %}
